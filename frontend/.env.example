# Voice Agent Integration - Primary Insights
# Phone number to receive verification calls (with country code)
NEXT_PUBLIC_VOICE_AGENT_RECIPIENT_PHONE=+1234567890

# Phone number configured for outgoing calls
NEXT_PUBLIC_VOICE_AGENT_FROM_PHONE=+1234567890

# Demo company CIN for testing
NEXT_PUBLIC_DEMO_CIN=U00000XX0000XXX000000

# Demo company name for testing
NEXT_PUBLIC_DEMO_COMPANY_NAME=Your Company Name Private Limited

# Voice Agent API Credentials
# Get these from your voice agent provider dashboard
NEXT_PUBLIC_VOICE_AGENT_API_KEY=your_api_key_here
NEXT_PUBLIC_VOICE_AGENT_AGENT_ID=your_agent_id_here
NEXT_PUBLIC_VOICE_AGENT_API_URL=https://api.bolna.ai

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
