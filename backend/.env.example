# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_URL=http://localhost:11434
LLM_PRIORITY=gemini,openai,ollama

# JWT Authentication
JWT_SECRET=your_secure_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# External API Keys for Credit Appraisal
CIBIL_API_KEY=your_cibil_api_key_here
MCA_API_KEY=your_mca_api_key_here
ECOURTS_API_KEY=your_ecourts_api_key_here
PDF_PARSER_API_KEY=your_pdf_parser_api_key_here
NEWS_API_KEY=your_newsapi_key_here

# App Configuration
APP_NAME=Credit Appraisal Engine
DEBUG=true